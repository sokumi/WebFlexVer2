@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment WebHostEnvironment

@{
    var title = ViewData["Title"]?.ToString() ?? "Dashboard";

    var controllerName = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLowerInvariant() ?? "";
    var actionName = ViewContext.RouteData.Values["action"]?.ToString()?.ToLowerInvariant() ?? "";

    var pageCssUrl = $"/1.0.0/css/views/{controllerName}/{actionName}.css";
    var pageCssPath = System.IO.Path.Combine(
        WebHostEnvironment.WebRootPath,
        "1.0.0",
        "css",
        "views",
        controllerName,
        $"{actionName}.css"
    );

    var hasPageCss = System.IO.File.Exists(pageCssPath);
}

<!DOCTYPE html>
<html lang="ko" data-webflex-theme="light" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - WebFlexV2</title>
     <link rel="stylesheet" href="~/1.0.0/css/views/main/index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/1.0.0/css/app.css" asp-append-version="true" />

    @if (hasPageCss)
    {
        <link rel="stylesheet" href="@pageCssUrl" asp-append-version="true" />
    }
</head>
<body>
    <div class="wf-app">
        <aside id="wfSidebar" class="wf-sidebar">
            <div class="wf-brand">
                <span class="wf-brand-icon">
                    <i data-lucide="activity"></i>
                </span>
                <span class="wf-brand-text">
                    WebFlex
                    <small>Industrial Monitoring</small>
                </span>
            </div>

            <nav class="wf-nav">
                <div class="wf-nav-section">
                    <div class="wf-nav-title">Dashboard</div>

                    <a class="wf-nav-link" href="/" data-menu-path="/">
                        <i data-lucide="layout-dashboard"></i>
                        <span>메인</span>
                    </a>
                </div>

                <div class="wf-nav-section">
                    <div class="wf-nav-title">Device</div>

                    <a class="wf-nav-link" href="/device/dvc1000" data-menu-path="/device/dvc1000">
                        <i data-lucide="server"></i>
                        <span>디바이스 관리</span>
                    </a>

                    <a class="wf-nav-link" href="/device/dvc1010" data-menu-path="/device/dvc1010">
                        <i data-lucide="git-branch"></i>
                        <span>디바이스 태그 관리</span>
                    </a>
                </div>

                <div class="wf-nav-section">
                    <div class="wf-nav-title">OPC</div>

                    <a class="wf-nav-link" href="/opc/opc1000" data-menu-path="/opc/opc1000">
                        <i data-lucide="radio-receiver"></i>
                        <span>OPC 수집 관리</span>
                    </a>

                    <a class="wf-nav-link" href="/opc/opc1020" data-menu-path="/opc/opc1020">
                        <i data-lucide="sliders-horizontal"></i>
                        <span>Collector 옵션</span>
                    </a>

                    <a class="wf-nav-link" href="/opc/opc1030" data-menu-path="/opc/opc1030">
                        <i data-lucide="settings-2"></i>
                        <span>Client 옵션</span>
                    </a>

                    <a class="wf-nav-link" href="/opc/opc3000" data-menu-path="/opc/opc3000">
                        <i data-lucide="history"></i>
                        <span>History 조회</span>
                    </a>

                    <a class="wf-nav-link" href="/opc/opc4000" data-menu-path="/opc/opc4000">
                        <i data-lucide="database-zap"></i>
                        <span>Timescale 설정</span>
                    </a>
                </div>

                <div class="wf-nav-section">
                    <div class="wf-nav-title">System</div>

                    <a class="wf-nav-link" href="/system/svc1000" data-menu-path="/system/svc1000">
                        <i data-lucide="monitor-cog"></i>
                        <span>Windows Service</span>
                    </a>
                </div>

                <div class="wf-nav-section">
                    <div class="wf-nav-title">Test</div>

                    <a class="wf-nav-link" href="/test/tst1000" data-menu-path="/test/tst1000">
                        <i data-lucide="flask-conical"></i>
                        <span>UI 테스트</span>
                    </a>

                    <a class="wf-nav-link" href="/test/tst2000" data-menu-path="/test/tst2000">
                        <i data-lucide="server-cog"></i>
                        <span>디바이스 등록 테스트</span>
                    </a>

                    <a class="wf-nav-link" href="/test/tst2010" data-menu-path="/test/tst2010">
                        <i data-lucide="tags"></i>
                        <span>디바이스 태그 테스트</span>
                    </a>
                </div>

            </nav>

            <div class="wf-sidebar-bottom">
                <div class="wf-opc-status-card">
                    <div class="wf-opc-status-title">
                        <span class="wf-status-dot good"></span>
                        <span>OPC 서버 연결됨</span>
                    </div>
                    <div class="wf-opc-status-sub">192.168.210.136:8083</div>
                </div>

                <button id="btnSidebarToggle" class="wf-sidebar-collapse" type="button" aria-label="메뉴 접기">
                    <i data-lucide="chevron-left"></i>
                    <span>접기</span>
                </button>
            </div>
        </aside>

        <button id="wfSidebarBackdrop"
                class="wf-sidebar-backdrop"
                type="button"
                aria-label="메뉴 닫기"></button>

        <section class="wf-main">
            <header class="wf-topbar">
                <div class="wf-topbar-left">
                    <button id="btnMobileMenuToggle"
                            class="wf-btn-icon wf-mobile-menu-toggle"
                            type="button"
                            aria-label="메뉴 열기"
                            aria-controls="wfSidebar"
                            aria-expanded="false">
                        <i data-lucide="menu"></i>
                    </button>

                    <div class="wf-topbar-title-block">
                        <div class="wf-breadcrumb">
                            <span>위젯 대시보드</span>
                            <span>/</span>
                            <span>@title</span>
                        </div>
                    </div>
                </div>

                <div class="wf-topbar-right">
                    <span id="lblHeaderClock" class="wf-header-clock">--:--:--</span>

                    <span class="wf-header-status">
                        <i data-lucide="wifi"></i>
                        <span>Connected</span>
                    </span>

                    <button class="wf-btn-icon wf-header-icon" type="button" aria-label="알림">
                        <i data-lucide="bell"></i>
                        <span class="wf-notification-dot"></span>
                    </button>

                    <button class="wf-btn-icon wf-header-icon" type="button" data-webflex-theme-toggle aria-label="테마 변경">
                        <i data-lucide="moon"></i>
                    </button>

                    <div class="wf-user-chip">
                        @* <span class="wf-user-avatar">A</span> *@
                        <span>Admin</span>
                    </div>

                    <a class="wf-btn-icon wf-header-icon" href="/auth/logout" aria-label="로그아웃">
                        <i data-lucide="log-out"></i>
                    </a>
                </div>
            </header>

            <main class="wf-page">
                @RenderBody()
            </main>
        </section>
    </div>

    <div id="wfToastHost" class="wf-toast-host" aria-live="polite" aria-atomic="true"></div>

    <script src="~/1.0.0/js/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>