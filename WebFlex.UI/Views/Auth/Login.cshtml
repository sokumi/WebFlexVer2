@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "로그인";

    var returnUrl = ViewData["ReturnUrl"]?.ToString();
    if (string.IsNullOrWhiteSpace(returnUrl))
    {
        returnUrl = Context.Request.Query["returnUrl"].ToString();
    }

    if (string.IsNullOrWhiteSpace(returnUrl))
    {
        returnUrl = "/";
    }

    var loginError = ViewData["LoginError"]?.ToString();
}

<div class="wf-login-page">
    <header class="wf-login-topbar">
        <a class="wf-login-brand" href="/auth/login" aria-label="WebFlex 로그인">
            <span class="wf-login-brand-icon">
                <i data-lucide="activity"></i>
            </span>
            <span>WebFlex OPC</span>
        </a>

        <button class="wf-btn-icon" type="button" data-webflex-theme-toggle aria-label="테마 변경">
            <i data-lucide="moon"></i>
        </button>
    </header>

    <main class="wf-login-main">
        <section class="wf-login-hero">
            <div class="wf-login-logo">
                <i data-lucide="gauge"></i>
            </div>

            <h1>WebFlex OPC</h1>
            <p>REAL-TIME OPC DATA PLATFORM</p>

            <form id="frmLogin" class="wf-login-card" method="post" action="/auth/login" autocomplete="off">
                @Html.AntiForgeryToken()

                <input type="hidden" id="hidReturnUrl" name="returnUrl" value="@returnUrl" />

                <div class="wf-login-card-header">
                    <div>
                        <h2>시스템 로그인</h2>
                        <p>계정 정보를 입력해 주세요.</p>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(loginError))
                {
                    <div id="loginErrorBox" class="alert alert-danger py-2 mb-3" role="alert">
                        @loginError
                    </div>
                }
                else
                {
                    <div id="loginErrorBox" class="alert alert-danger py-2 mb-3 d-none" role="alert"></div>
                }

                <div class="wf-login-field">
                    <label for="txtUserId">사용자 ID</label>
                    <input id="txtUserId"
                           name="userId"
                           type="text"
                           class="form-control"
                           placeholder="아이디 입력"
                           autocomplete="username" />
                </div>

                <div class="wf-login-field">
                    <label for="txtPassword">비밀번호</label>
                    <input id="txtPassword"
                           name="password"
                           type="password"
                           class="form-control"
                           placeholder="비밀번호 입력"
                           autocomplete="current-password" />
                </div>

                <button id="btnLogin" class="btn btn-primary wf-login-submit" type="submit">
                    로그인
                </button>

                <div class="wf-login-card-footer">
                    <button type="button" class="wf-login-link">
                        관리자 문의
                    </button>

                    <span>v4.0.1</span>
                </div>
            </form>

            <div class="wf-login-status">
                <span class="wf-login-status-dot"></span>
                <span>OPC 서버 연결됨 — 10.10.10.142:8083</span>
            </div>
        </section>
    </main>

    <footer class="wf-login-footer">
        © 2026 WebFlex OPC. All rights reserved.
    </footer>
</div>

@section Scripts {
    <script src="~/1.0.0/js/views/auth/login.js" asp-append-version="true"></script>
}