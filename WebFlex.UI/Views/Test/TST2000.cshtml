@{
    ViewData["Title"] = "디바이스 등록 테스트";
}

<div class="wf-page-layout wf-test-device-page">
    <section class="wf-test-device-layout">
        <article class="wf-card wf-grid-panel wf-test-device-list-card">
            <div class="wf-card-body">
                <div class="wf-grid-toolbar">
                    <div class="wf-grid-toolbar-left">
                        <div class="wf-grid-toolbar-title">
                            <span>디바이스 목록</span>
                            <span id="lblDeviceGridCount" class="wf-count-badge">0건</span>
                        </div>
                        <div class="wf-grid-toolbar-desc">
                            행을 선택하면 오른쪽 폼에 바인딩됩니다.
                        </div>
                    </div>

                    <div class="wf-grid-toolbar-right">
                        <div class="wf-grid-search">
                            <i data-lucide="search"></i>
                            <input id="txtGridKeyword"
                                   type="text"
                                   class="form-control"
                                   placeholder="코드/이름 검색" />
                        </div>

                        <button id="btnSearch" type="button" class="btn btn-outline-secondary btn-sm">
                            <i data-lucide="refresh-cw"></i>
                            조회
                        </button>

                        <button id="btnNew" type="button" class="btn btn-primary btn-sm">
                            <i data-lucide="plus"></i>
                            신규
                        </button>
                    </div>
                </div>

                <div class="wf-grid-wrap wf-fill">
                    <div id="gridDevice" class="wf-grid"></div>
                </div>

                <div class="wf-grid-footer">
                    <span id="lblGridSummary">총 0건</span>
                    <span id="lblSelectedDevice">선택 없음</span>
                </div>
            </div>
        </article>

        <article class="wf-card wf-form-panel wf-test-device-form-card">
            <div class="wf-card-header">
                <div>
                    <div class="wf-title-with-badge">
                        <h3 class="wf-card-title">디바이스 상세</h3>
                        <span id="lblFormMode" class="wf-mode-badge create">신규</span>
                    </div>
                    <div class="wf-card-subtitle">등록/수정할 디바이스 정보를 입력합니다.</div>
                </div>

                <div class="wf-test-device-form-actions">
                    <button id="btnDelete" type="button" class="btn btn-outline-danger btn-sm">
                        <i data-lucide="trash-2"></i>
                        삭제
                    </button>
                    <button id="btnSave" type="button" class="btn btn-primary btn-sm">
                        <i data-lucide="save"></i>
                        저장
                    </button>
                </div>
            </div>

            <div class="wf-card-body">
                <input id="hidId" type="hidden" />

                <section class="wf-device-section">
                    <h4 class="wf-section-title">
                        <i data-lucide="info"></i>
                        <span>기본 정보</span>
                    </h4>

                    <div class="wf-form-grid-2">
                        <div class="wf-form-field">
                            <label for="txtDeviceCode" class="form-label">디바이스 코드</label>
                            <input id="txtDeviceCode"
                                   type="text"
                                   class="form-control"
                                   placeholder="자동 생성"
                                   disabled />
                        </div>

                        <div class="wf-form-field">
                            <label for="txtDeviceName" class="form-label">디바이스명 <span class="text-danger">*</span></label>
                            <input id="txtDeviceName"
                                   type="text"
                                   class="form-control"
                                   placeholder="디바이스명" />
                        </div>

                        <div class="wf-form-field">
                            <label for="selDeviceType" class="form-label">디바이스 타입</label>
                            <select id="selDeviceType" class="form-select"></select>
                        </div>

                        <div class="wf-form-field">
                            <label for="txtDeviceAddress" class="form-label">주소</label>
                            <input id="txtDeviceAddress"
                                   type="text"
                                   class="form-control"
                                   placeholder="192.168.0.10" />
                        </div>

                        <div class="wf-form-field">
                            <label for="txtPort" class="form-label">포트</label>
                            <input id="txtPort"
                                   type="number"
                                   class="form-control"
                                   value="4840" />
                        </div>

                        <div class="wf-form-field">
                            <label for="txtSortOrder" class="form-label">정렬</label>
                            <input id="txtSortOrder"
                                   type="number"
                                   class="form-control"
                                   value="0" />
                        </div>
                    </div>
                </section>

                <section class="wf-device-section">
                    <h4 class="wf-section-title">
                        <i data-lucide="link"></i>
                        <span>연결 설정</span>
                    </h4>

                    <div class="wf-form-grid-1">
                        <div class="wf-form-field">
                            <label for="txtEndpointUrl" class="form-label">Endpoint URL</label>
                            <div class="input-group">
                                <input id="txtEndpointUrl"
                                       type="text"
                                       class="form-control"
                                       placeholder="비워두면 자동 생성" />
                                <button id="btnPreviewEndpoint" type="button" class="btn btn-outline-secondary">
                                    <i data-lucide="wand-2"></i>
                                    자동 생성
                                </button>
                            </div>
                        </div>

                        <div class="wf-form-grid-2">
                            <div class="wf-form-field">
                                <label for="txtPublishingIntervalMs" class="form-label">
                                    Publishing Interval <span class="wf-unit">ms</span>
                                </label>
                                <input id="txtPublishingIntervalMs"
                                       type="number"
                                       class="form-control"
                                       value="1000" />
                            </div>

                            <div class="wf-form-field">
                                <label for="txtSamplingIntervalMs" class="form-label">
                                    Sampling Interval <span class="wf-unit">ms</span>
                                </label>
                                <input id="txtSamplingIntervalMs"
                                       type="number"
                                       class="form-control"
                                       value="1000" />
                            </div>
                        </div>
                    </div>
                </section>

                <section class="wf-device-section">
                    <h4 class="wf-section-title">
                        <i data-lucide="shield-check"></i>
                        <span>보안 / 권한</span>
                    </h4>

                    <div class="wf-form-grid-2">
                        <div class="wf-form-field">
                            <label for="txtUserName" class="form-label">사용자명</label>
                            <input id="txtUserName"
                                   type="text"
                                   class="form-control"
                                   placeholder="username" />
                        </div>

                        <div class="wf-form-field">
                            <label for="txtPassword" class="form-label">비밀번호</label>
                            <input id="txtPassword"
                                   type="password"
                                   class="form-control"
                                   placeholder="password" />
                        </div>

                        <div class="wf-switch-box">
                            <label class="form-check form-switch">
                                <input id="chkCollect" type="checkbox" class="form-check-input" checked />
                                <span class="form-check-label">수집 사용</span>
                            </label>

                            <label class="form-check form-switch">
                                <input id="chkEnabled" type="checkbox" class="form-check-input" checked />
                                <span class="form-check-label">사용 여부</span>
                            </label>

                            <label class="form-check form-switch">
                                <input id="chkUseSecurity" type="checkbox" class="form-check-input" />
                                <span class="form-check-label">보안 사용</span>
                            </label>

                            <label class="form-check form-switch">
                                <input id="chkUseAnonymous" type="checkbox" class="form-check-input" checked />
                                <span class="form-check-label">익명 접속</span>
                            </label>
                        </div>
                    </div>
                </section>

                <section class="wf-device-section">
                    <h4 class="wf-section-title">
                        <i data-lucide="file-text"></i>
                        <span>설명</span>
                    </h4>

                    <div class="wf-form-field">
                        <textarea id="txtDescription"
                                  class="form-control"
                                  rows="4"
                                  placeholder="디바이스 설명"></textarea>
                    </div>
                </section>
            </div>
        </article>
    </section>
</div>

@section Scripts {
    <script src="~/1.0.0/js/views/test/tst2000.js" asp-append-version="true"></script>
}