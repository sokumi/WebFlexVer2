@{
    ViewData["Title"] = "UI 테스트";
}

<div class="wf-test-page">
    <section class="wf-page-header">
        <div>
            <div class="wf-breadcrumb">
                <span>Test</span>
                <span>/</span>
                <span>TST1000</span>
            </div>
            <h2 class="wf-page-title">UI 컴포넌트 테스트</h2>
        </div>

        <div class="wf-test-actions">
            <button id="btnReload" type="button" class="btn btn-primary btn-sm">
                다시 조회
            </button>

            <button id="btnOpenModal" type="button" class="btn btn-outline-secondary btn-sm">
                모달 열기
            </button>
        </div>
    </section>

    <section class="wf-stat-grid wf-test-summary">
        <article class="wf-stat-card">
            <span class="wf-stat-icon">
                <i data-lucide="server"></i>
            </span>
            <div>
                <div class="wf-stat-label">Device</div>
                <div id="lblDeviceCount" class="wf-stat-value">0</div>
            </div>
        </article>

        <article class="wf-stat-card">
            <span class="wf-stat-icon">
                <i data-lucide="tag"></i>
            </span>
            <div>
                <div class="wf-stat-label">Tag</div>
                <div id="lblTagCount" class="wf-stat-value">0</div>
            </div>
        </article>

        <article class="wf-stat-card">
            <span class="wf-stat-icon">
                <i data-lucide="circle-check"></i>
            </span>
            <div>
                <div class="wf-stat-label">Good</div>
                <div id="lblGoodCount" class="wf-stat-value">0</div>
            </div>
        </article>

        <article class="wf-stat-card">
            <span class="wf-stat-icon">
                <i data-lucide="circle-alert"></i>
            </span>
            <div>
                <div class="wf-stat-label">Bad</div>
                <div id="lblBadCount" class="wf-stat-value">0</div>
            </div>
        </article>
    </section>

    <section class="wf-test-layout">
        <article class="wf-card">
            <div class="wf-card-header">
                <div>
                    <h3 class="wf-card-title">입력 폼 테스트</h3>
                    <div class="wf-card-subtitle">API POST, form-control, checkbox 예시</div>
                </div>
                <span class="wf-status good">Ready</span>
            </div>

            <div class="wf-card-body">
                <form id="frmTest" autocomplete="off">
                    <div class="mb-3">
                        <label for="txtName" class="form-label">이름</label>
                        <input id="txtName" class="form-control" type="text" placeholder="테스트 이름 입력" />
                    </div>

                    <div class="mb-3">
                        <label for="txtDescription" class="form-label">설명</label>
                        <textarea id="txtDescription" class="form-control" rows="3" placeholder="설명 입력"></textarea>
                    </div>

                    <label class="form-check mb-3">
                        <input id="chkIsEnabled" class="form-check-input" type="checkbox" checked />
                        <span class="form-check-label">사용 여부</span>
                    </label>

                    <button id="btnSave" class="btn btn-primary" type="submit">
                        저장 테스트
                    </button>
                </form>
            </div>
        </article>

        <article class="wf-card">
            <div class="wf-card-header">
                <div>
                    <h3 class="wf-card-title">차트 테스트</h3>
                    <div class="wf-card-subtitle">Apache ECharts 기본 사용 예시</div>
                </div>
            </div>

            <div class="wf-card-body">
                <div id="testChart" class="wf-test-chart"></div>
            </div>
        </article>
    </section>

    <section class="wf-card mt-3">
        <div class="wf-card-header">
            <div>
                <h3 class="wf-card-title">Tabulator 그리드 테스트</h3>
                <div class="wf-card-subtitle">WebFlexGrid wrapper 사용 예시</div>
            </div>

            <div class="wf-test-grid-actions">
                <button id="btnClearGrid" type="button" class="btn btn-outline-secondary btn-sm">
                    비우기
                </button>
                <button id="btnLoadGrid" type="button" class="btn btn-primary btn-sm">
                    그리드 조회
                </button>
            </div>
        </div>

        <div class="wf-card-body">
            <div class="wf-grid-wrap">
                <div id="gridTest" class="wf-grid"></div>
            </div>
        </div>
    </section>
</div>

<div class="modal fade" id="testModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content wf-modal-content">
            <div class="modal-header">
                <h5 class="modal-title">테스트 모달</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="닫기"></button>
            </div>
            <div class="modal-body">
                Bootstrap Modal 동작 테스트입니다.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    닫기
                </button>
                <button id="btnModalConfirm" type="button" class="btn btn-primary">
                    확인
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/1.0.0/js/views/test/tst1000.js" asp-append-version="true"></script>
}