@{
    ViewData["Title"] = "OPC 수집 관리";
}

<div class="page-device page-opc-control">
    <section class="page-toolbar">
        <input id="txtDeviceId" class="opc-device-id" type="number" placeholder="DeviceId" />

        <button id="btnRestartDevice" class="btn-basic" type="button">선택 디바이스 재구독</button>
        <button id="btnRestartAllDevices" class="btn-basic" type="button">전체 디바이스 재구독</button>
        <button id="btnStopSubscription" class="btn-basic" type="button">구독 중지</button>
        <button id="btnStartSubscription" class="btn-basic" type="button">구독 재시작</button>
        <button id="btnStopDbSave" class="btn-basic" type="button">DB 저장 중지</button>
        <button id="btnStartDbSave" class="btn-basic" type="button">DB 저장 재시작</button>
        <button id="btnRestartProcess" class="btn-basic danger" type="button">전체 재가동</button>
        <button id="btnRefresh" class="btn-basic" type="button">새로고침</button>
    </section>

    <section class="opc-status-panel">
        <div class="opc-status-card">
            <div class="opc-status-title">Collector 상태</div>

            <table class="basic-grid">
                <tbody>
                    <tr>
                        <th>디바이스 수</th>
                        <td id="lblDeviceCount">-</td>
                    </tr>
                    <tr>
                        <th>구독 태그 수</th>
                        <td id="lblSubscribedCount">-</td>
                    </tr>
                    <tr>
                        <th>Queue</th>
                        <td id="lblQueueCount">-</td>
                    </tr>
                    <tr>
                        <th>Enqueued</th>
                        <td id="lblTotalEnqueued">-</td>
                    </tr>
                    <tr>
                        <th>Inserted</th>
                        <td id="lblTotalInserted">-</td>
                    </tr>
                    <tr>
                        <th>구독 중지 상태</th>
                        <td id="lblSubscriptionStopped">-</td>
                    </tr>
                    <tr>
                        <th>DB 저장 중지 상태</th>
                        <td id="lblDbSaveStopped">-</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="opc-log-card">
            <div class="opc-status-title">실행 로그</div>
            <div id="logBox" class="opc-log-box"></div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="~/1.0.0/js/views/opc/opc1000.js" asp-append-version="true"></script>
}