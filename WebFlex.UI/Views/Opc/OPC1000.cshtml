@{
    ViewData["Title"] = "OPC 수집 관리";
}

<div class="wf-page-layout wf-opc-page is-scroll">
    <section class="wf-opc-summary-grid">
        <article class="wf-opc-summary-card is-success">
            <div class="wf-opc-summary-icon">
                <i data-lucide="server"></i>
            </div>
            <span>전체 디바이스</span>
            <strong id="lblDeviceCount">-</strong>
            <small id="lblStoppedCount">-</small>
        </article>

        <article class="wf-opc-summary-card is-primary">
            <div class="wf-opc-summary-icon">
                <i data-lucide="badge-check"></i>
            </div>
            <span>구독 태그</span>
            <strong id="lblSubscribedCount">-</strong>
            <small>실시간 수집중</small>
        </article>

        <article class="wf-opc-summary-card is-warning">
            <div class="wf-opc-summary-icon">
                <i data-lucide="database"></i>
            </div>
            <span>Snapshot Rows</span>
            <strong id="lblTotalSnapshotRows">-</strong>
            <small id="lblSnapshotTime">마지막 -</small>
        </article>

        <article class="wf-opc-summary-card is-success">
            <div class="wf-opc-summary-icon">
                <i data-lucide="cloud-upload"></i>
            </div>
            <span>DB Inserted</span>
            <strong id="lblTotalInserted">-</strong>
            <small>정상 적재중</small>
        </article>

        <article class="wf-opc-summary-card is-neutral">
            <div class="wf-opc-summary-icon">
                <i data-lucide="info"></i>
            </div>
            <span>Collector 버전</span>
            <strong id="lblCollectorVersion">-</strong>
            <small id="lblCollectorDbStatus">DB 상태 -</small>
        </article>
    </section>

    <section class="wf-opc-section-title">
        <div>
            <h3>디바이스 수집 상태</h3>
            <span id="lblDeviceSummaryText">0개 디바이스</span>
        </div>

        <div class="wf-opc-section-actions">
            <button type="button" id="btnRefreshStatus" class="btn btn-outline-secondary btn-sm">
                <i data-lucide="refresh-cw"></i>
                새로고침
            </button>

            <button type="button" id="btnRestartAllSubscription" class="btn btn-outline-primary btn-sm">
                <i data-lucide="rotate-cw"></i>
                전체 구독 자동 재구독
            </button>
        </div>
    </section>

    <section id="deviceCardHost" class="wf-opc-device-grid">
        <article class="wf-opc-empty-card">
            <i data-lucide="server-off"></i>
            <strong>디바이스 상태를 조회하고 있습니다.</strong>
            <span>Collector 상태와 디바이스 런타임 정보를 불러오는 중입니다.</span>
        </article>
    </section>

    <template id="deviceCardTemplate">
        <article class="wf-opc-device-card is-stopped" data-device-card>
            <div class="wf-opc-device-head">
                <div class="wf-opc-device-title">
                    <span class="wf-opc-device-icon">
                        <i data-lucide="cpu"></i>
                    </span>
                    <div>
                        <h4 data-field="deviceName">-</h4>
                        <small data-field="deviceCode">-</small>
                    </div>
                </div>

                <span class="wf-opc-device-status is-stopped" data-field="statusBadge">
                    <span class="wf-status-dot"></span>
                    <span data-field="statusText">구독중지</span>
                </span>
            </div>

            <div class="wf-opc-device-type" data-field="deviceType">OPCUA</div>

            <div class="wf-opc-endpoint">
                <i data-lucide="link"></i>
                <span data-field="endpoint">-</span>
            </div>

            <div class="wf-opc-device-metrics">
                <div>
                    <span>구독 태그</span>
                    <strong>
                        <span data-field="subscribedCount">-</span>
                        <small>/ <span data-field="tagCount">-</span></small>
                    </strong>
                </div>
                <div>
                    <span>현재값</span>
                    <strong>
                        <span data-field="currentValueCount">-</span>
                        <small>rows</small>
                    </strong>
                </div>
                <div>
                    <span>Snapshot</span>
                    <strong data-field="totalSnapshotRows">-</strong>
                </div>
                <div>
                    <span>DB Insert</span>
                    <strong data-field="totalInserted">-</strong>
                </div>
            </div>

            <div class="wf-opc-progress">
                <span data-field="progressBar" style="width:0%"></span>
            </div>

            <div class="wf-opc-device-footer">
                <div class="wf-opc-device-time">
                    <span>
                        <i data-lucide="timer"></i>
                        <span data-field="percent">0%</span>
                    </span>
                    <span>
                        <i data-lucide="clock"></i>
                        <span data-field="updatedTime">-</span>
                    </span>
                </div>

                <div class="wf-opc-device-actions">
                    <button type="button"
                            class="btn btn-outline-primary btn-sm"
                            data-subscription-button
                            data-device-id=""
                            data-subscription-action="start">
                        <i data-lucide="play-circle" data-field="actionIcon"></i>
                        <span data-field="actionText">구독시작</span>
                    </button>

                    <span class="wf-opc-db-badge">
                        <i data-lucide="save"></i>
                        <span data-field="dbStatusText">DB대기</span>
                    </span>
                </div>
            </div>
        </article>
    </template>

    <section class="wf-card wf-opc-log-card is-collapsed" id="opcLogCard">
        <header class="wf-opc-log-header">
            <div class="wf-opc-log-title">
                <strong>실행 로그</strong>
                <span id="lblLogCount">0개 항목</span>
            </div>

            <div class="wf-opc-log-actions">
                <button type="button" id="btnClearLogs" class="btn btn-outline-secondary btn-sm">
                    <i data-lucide="eraser"></i>
                    로그 지우기
                </button>

                <button type="button" id="btnLoadLogs" class="btn btn-outline-secondary btn-sm">
                    <i data-lucide="refresh-cw"></i>
                    로그 불러오기
                </button>

                <button type="button" id="btnToggleLogs" class="wf-opc-log-toggle">
                    <span id="lblLogToggleText">펼치기</span>
                    <i data-lucide="chevron-down"></i>
                </button>
            </div>
        </header>

        <div class="wf-opc-log-body">
            <div id="logBox" class="wf-opc-log-box"></div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="~/1.0.0/js/views/opc/opc1000.js" asp-append-version="true"></script>
}
