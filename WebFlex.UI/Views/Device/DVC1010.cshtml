@{
    ViewData["Title"] = "디바이스 태그 관리";
}

<div class="wf-page-layout wf-test-tag-page">
    <section class="wf-tag-controlbar">
        <div class="wf-tag-device-select">
            <label for="selDevice">디바이스</label>
            <select id="selDevice" class="form-select form-select-sm">
                <option value="">디바이스 선택</option>
            </select>
        </div>

        <div id="lblDeviceStatus" class="wf-tag-connect-chip is-empty">
            <span class="wf-status-dot"></span>
            <span>미선택</span>
        </div>

        <div id="lblEndpoint" class="wf-tag-endpoint-chip">Endpoint 없음</div>

        <div class="wf-tag-controlbar-actions">
            <span class="wf-tag-total-text">
                태그 <strong id="lblTagCount">0개</strong>
            </span>

            <button id="btnOpenTagDrawer" type="button" class="btn btn-outline-primary btn-sm">
                <i data-lucide="panel-right-open"></i>
                태그 등록
            </button>
        </div>
    </section>

    <section class="wf-tag-content">
        <section class="wf-card wf-tag-list-card">
            <div class="wf-card-body">
                <div class="wf-grid-toolbar">
                    <div class="wf-grid-toolbar-left">
                        <div class="wf-grid-toolbar-title">
                            <span>등록된 태그</span>
                            <span id="lblGridTagCount" class="wf-count-badge">0건</span>
                        </div>
                        <div class="wf-grid-toolbar-desc">
                            선택한 태그를 클릭하면 오른쪽에서 상세 정보를 수정할 수 있습니다.
                        </div>
                    </div>

                    <div class="wf-grid-toolbar-right">
                        <div class="wf-grid-search">
                            <i data-lucide="search"></i>
                            <input id="txtTagKeyword" type="text" class="form-control" placeholder="태그코드/명/설명 검색" />
                        </div>

                        <button id="btnSearch" type="button" class="btn btn-outline-secondary btn-sm">
                            <i data-lucide="refresh-cw"></i>
                            조회
                        </button>

                        <button id="btnDelete" type="button" class="btn btn-outline-danger btn-sm">
                            <i data-lucide="trash-2"></i>
                            삭제
                        </button>
                    </div>
                </div>

                <div class="wf-grid-wrap wf-fill">
                    <div id="gridTag" class="wf-grid"></div>
                </div>

                <div class="wf-grid-footer">
                    <span id="lblGridSummary">총 0건</span>
                    <span id="lblSelectedTag">선택 없음</span>
                </div>
            </div>
        </section>

        <aside id="tagDetailPanel" class="wf-tag-detail-panel is-hidden">
            <div class="wf-tag-detail-header">
                <div>
                    <strong>태그 상세</strong>
                    <span id="lblDetailSubTitle">선택 없음</span>
                </div>
                <button id="btnCloseTagDetail" type="button" class="btn btn-light btn-sm">
                    <i data-lucide="x"></i>
                </button>
            </div>

            <div class="wf-tag-detail-body">
                <input id="txtDetailId" type="hidden" />
                <input id="txtDetailIdView" type="hidden" />
                <input id="txtDetailDeviceId" type="hidden" />
                <input id="txtDetailGroupId" type="hidden" />
                <input id="numDetailSamplingIntervalMs" type="hidden" />

                <div class="wf-form-row">
                    <label>설명</label>
                    <input id="txtDetailDescription"
                           type="text"
                           class="form-control"
                           placeholder="설명" />
                </div>

                <div class="wf-form-grid two">
                    <div class="wf-form-row">
                        <label>NodeId</label>
                        <input id="txtDetailNodeId"
                               type="text"
                               class="form-control" />
                    </div>

                    <div class="wf-form-row">
                        <label>태그명</label>
                        <input id="txtDetailTagName"
                               type="text"
                               class="form-control" />
                    </div>
                </div>

                <div class="wf-form-grid two">
                    <div class="wf-form-row">
                        <label>데이터 타입</label>
                        <select id="selDetailDataType" class="form-select"></select>
                    </div>

                    <div class="wf-form-row">
                        <label>권한</label>
                        <select id="selDetailProtectType" class="form-select"></select>
                    </div>
                </div>

                <div class="wf-form-grid two">
                    <div class="wf-form-row">
                        <label>대시보드</label>
                        <label class="wf-switch-field">
                            <input id="chkDetailDashboard"
                                   type="checkbox"
                                   class="form-check-input" />
                            <span>표시</span>
                        </label>
                    </div>

                    <div class="wf-form-row">
                        <label>정렬</label>
                        <input id="numDetailSortOrder"
                               type="number"
                               class="form-control" />
                    </div>
                </div>

                <div class="wf-check-grid three">
                    <label class="wf-switch-field">
                        <input id="chkDetailCollect"
                               type="checkbox"
                               class="form-check-input" />
                        <span>수집</span>
                    </label>

                    <label class="wf-switch-field">
                        <input id="chkDetailSaveDb"
                               type="checkbox"
                               class="form-check-input" />
                        <span>DB 저장</span>
                    </label>

                    <label class="wf-switch-field">
                        <input id="chkDetailEnabled"
                               type="checkbox"
                               class="form-check-input" />
                        <span>사용</span>
                    </label>
                </div>

                <div class="wf-form-grid two">
                    <div class="wf-form-row">
                        <label>&nbsp;</label>
                        <input id="txtDetailTestValue"
                               type="text"
                               class="form-control"
                               placeholder="테스트 값" />
                    </div>

                    <div class="wf-form-row">
                        <label>&nbsp;</label>
                        <button id="btnTestTagDetail"
                                type="button"
                                class="btn btn-outline-primary">
                            테스트
                        </button>
                    </div>
                </div>

                <textarea id="txtDetailSetting"
                          class="form-control wf-code-editor"
                          rows="8"
                          spellcheck="false"
                          autocomplete="off"
                          autocapitalize="off"
                          placeholder='계산식'></textarea>
            </div>

            <div class="wf-tag-detail-footer">
                <button id="btnSaveTagDetail" type="button" class="btn btn-primary btn-sm">
                    <i data-lucide="save"></i>
                    저장
                </button>
            </div>
        </aside>
    </section>
</div>

<div id="tagRegisterModal" class="wf-tag-popup wf-tag-modal" aria-hidden="true">
    <div class="wf-tag-popup-backdrop" data-popup-close></div>

    <section class="wf-tag-popup-panel" role="dialog" aria-modal="true" aria-labelledby="tagRegisterModalTitle">
        <header class="wf-tag-popup-header">
            <div>
                <h3 id="tagRegisterModalTitle">태그 등록</h3>
                <p>
                    <span data-device-name>-</span>
                    <span>좌측 트리에서 노드를 선택하고 우측에서 수정 후 등록하세요</span>
                </p>
            </div>

            <div class="wf-tag-popup-header-actions">
                <span class="wf-popup-loaded-badge d-none" data-loaded-count>0개 로드됨</span>
                <button type="button" class="wf-popup-close" data-popup-close aria-label="닫기">
                    <i data-lucide="x"></i>
                </button>
            </div>
        </header>

        <div class="wf-tag-popup-body">
            <aside class="wf-tag-tree-panel">
                <div class="wf-tag-panel-title-row">
                    <h4>OPC 노드 트리</h4>
                    <div class="wf-tag-tree-summary">
                        <span data-selected-count>0/0</span>
                        <button type="button" data-select-all>전체 선택</button>
                    </div>
                </div>

                <div class="wf-tag-tree-scroll" data-tree-host>
                    <div class="wf-tag-empty">
                        <i data-lucide="git-branch"></i>
                        <strong>노드를 불러오지 않았습니다.</strong>
                        <span>태그 등록 버튼을 누르면 OPC 노드를 조회합니다.</span>
                    </div>
                </div>
            </aside>

            <section class="wf-edit-panel">
                <div class="wf-edit-toolbar">
                    <div class="wf-edit-left">
                        <label class="form-check">
                            <input type="checkbox" class="form-check-input" data-check-all />
                            <span class="form-check-label">전체선택</span>
                        </label>
                        <span data-selected-text>0/0개 선택</span>
                    </div>

                    <div class="wf-edit-actions">
                        <button type="button" class="btn btn-sm btn-outline-success" data-collect-on>수집 ON</button>
                        <button type="button" class="btn btn-sm btn-light" data-collect-off>수집 OFF</button>
                        <span class="wf-divider"></span>
                        <button type="button" class="btn btn-sm btn-outline-success" data-use-on>사용 ON</button>
                        <button type="button" class="btn btn-sm btn-light" data-use-off>사용 OFF</button>
                    </div>

                    <span class="wf-edit-loaded-text" data-loaded-text>총 0개 노드 로드됨</span>
                </div>

                <div class="wf-edit-table-wrap">
                    <table class="wf-edit-table">
                        <thead>
                            <tr>
                                <th class="wf-check-col">✓</th>
                                <th>원본 노드명</th>
                                <th>태그명 <span class="text-danger">*</span></th>
                                <th>데이터 타입</th>
                                <th>권한</th>
                                <th>설명</th>
                                <th>수집</th>
                                <th>사용</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody data-selected-host>
                        </tbody>
                    </table>

                    <div class="wf-tag-empty" data-empty-host>
                        <i data-lucide="git-branch"></i>
                        <strong>등록할 노드를 선택하세요</strong>
                        <span>좌측 OPC 노드 트리에서 체크하면 이곳에 편집 가능한 테이블이 표시됩니다.</span>
                        <small>폴더 우측의 체크박스로 하위 노드를 한번에 선택할 수 있어요.</small>
                    </div>
                </div>
            </section>
        </div>

        <footer class="wf-tag-popup-footer">
            <button type="button" class="btn btn-outline-secondary" data-popup-close>취소</button>
            <button type="button" class="btn btn-success" data-save>
                <i data-lucide="plus-circle"></i>
                <span data-save-text>태그 등록</span>
            </button>
        </footer>
    </section>
</div>

