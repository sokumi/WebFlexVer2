@{
    ViewData["Title"] = "메인";
}

<div class="wf-page-layout wf-main-dashboard is-scroll">
    <section id="currentGroupPanel" class="wf-current-filter-card">
        <div class="wf-current-filter-head">
            <div>
                <strong>그룹 선택</strong>
                <span id="lblGroupSummary">전체 그룹</span>
            </div>

            <button type="button"
                    id="btnToggleGroupPanel"
                    class="wf-current-filter-toggle"
                    aria-expanded="true">
                <span id="lblGroupToggleText">접기</span>
                <i data-lucide="chevron-up"></i>
            </button>
        </div>

        <div id="groupFilterBody" class="wf-current-filter-body">
            <div id="groupFilterHost" class="wf-current-group-list">
                <button type="button" class="wf-current-group-chip is-active" data-group-id="">
                    전체
                    <span>0</span>
                </button>
            </div>
        </div>
    </section>

    <section class="wf-card wf-current-grid-card">
        <header class="wf-current-grid-header">
            <div class="wf-current-grid-header-main">
                <div class="wf-current-title-line">
                    <strong>실시간 태그 리스트</strong>
                    <span id="lblVisibleRange">0 ~ 0</span>

                    <div class="wf-current-status-row">
                        <span class="wf-current-status-chip">
                            전체 <strong id="lblTotalCount">0</strong>
                        </span>
                        <span class="wf-current-status-chip">
                            로드 <strong id="lblLoadedCount">0</strong>
                        </span>
                        <span class="wf-current-status-chip">
                            수신 <strong id="lblUpdateCount">0</strong>
                        </span>
                        <span id="lblStreamChip" class="wf-current-stream-chip is-wait">
                            <span class="wf-status-dot"></span>
                            <span id="lblStreamStatus">연결 전</span>
                        </span>
                    </div>
                </div>

                <div class="wf-current-action-line">
                    <button id="btnRefreshCurrent" type="button" class="btn btn-outline-secondary btn-sm">
                        <i data-lucide="refresh-cw"></i>
                        새로고침
                    </button>

                    <div class="wf-grid-search wf-current-search">
                        <i data-lucide="search"></i>
                        <input id="txtKeyword"
                               type="text"
                               class="form-control"
                               placeholder="태그 / 그룹 / 값 검색" />
                    </div>
                </div>
            </div>
        </header>

        <div class="wf-current-table-head">
            <table class="wf-current-table">
                <colgroup>
                    <col style="width: 60px;" />
                    <col style="width: 220px;" />
                    <col style="width: 110px;" />
                    <col style="width: 170px;" />
                    <col style="width: 180px;" />
                    <col style="width: 220px;" />
                    <col style="width: 110px;" />
                    <col style="width: 130px;" />
                    <col style="width: 170px;" />
                    <col style="width: 170px;" />
                </colgroup>
                <thead>
                    <tr>
                        <th>번호</th>
                        <th>수집 항목 설정</th>
                        <th>그룹</th>
                        <th>태그 ID</th>
                        <th>현재값</th>
                        <th>변환값</th>
                        <th>상태</th>
                        <th>업데이트</th>
                        <th>Source Time</th>
                        <th>Updated Time</th>
                    </tr>
                </thead>
            </table>
        </div>

        <div id="currentValueScroll" class="wf-current-scroll">
            <table class="wf-current-table">
                <colgroup>
                    <col style="width: 60px;" />
                    <col style="width: 220px;" />
                    <col style="width: 110px;" />
                    <col style="width: 170px;" />
                    <col style="width: 180px;" />
                    <col style="width: 220px;" />
                    <col style="width: 110px;" />
                    <col style="width: 130px;" />
                    <col style="width: 170px;" />
                    <col style="width: 170px;" />
                </colgroup>
                <tbody id="currentValueBody">
                    <tr>
                        <td colspan="10" class="wf-current-empty-cell">데이터를 불러오는 중입니다.</td>
                    </tr>
                </tbody>
            </table>

            <div id="currentValueLoading" class="wf-current-loading d-none">
                <span class="spinner-border spinner-border-sm"></span>
                데이터를 불러오는 중입니다.
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="~/1.0.0/js/views/main/index.js" asp-append-version="true"></script>
}